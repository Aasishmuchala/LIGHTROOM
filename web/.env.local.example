# LightMatch — server environment (copy to .env.local and fill in; .env.local is gitignored)

# Omega (kesarcloud) AI gateway key — the Bearer token used SERVER-SIDE by
# src/app/api/analyze/route.ts to call https://omega.kesarcloud.in/v1/messages.
#
# This is a FALLBACK: the client normally sends the user's own key in the
# x-omega-key request header (entered in the UI, stored in localStorage under
# lm_key). If that header is absent, the route falls back to this env var.
#
# Never commit a real key. Leave this file with an empty value.
OMEGA_API_KEY=
